MAIL_PORT=25
MAIL_FROM_NAME="IMPEDIMENTOS"
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

LDAP_LOGGING=true
LDAP_CONNECTION=default
LDAP_HOST=172.18.206.36
LDAP_USERNAME="cancilleria\\websre"
LDAP_PASSWORD="H5#h9$lT=L"
LDAP_PORT=389
LDAP_BASE_DN="DC=cancilleria,DC=sre,DC=gob,DC=mx"
